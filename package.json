{
  "name": "fetch-problem-details",
  "version": "1.0.0",
  "description": "Utilities for creating and handling HTTP Problem Responses in TypeScript.",
  "homepage": "https://github.com/EskiMojo14/fetch-problem-details#readme",
  "bugs": {
    "url": "https://github.com/EskiMojo14/fetch-problem-details/issues"
  },
  "license": "MIT",
  "author": "EskiMojo14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EskiMojo14/fetch-problem-details.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./standard": "./dist/standard.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vpr build",
    "prepare": "vp config",
    "prepack": "publint",
    "attw": "attw --profile esm-only",
    "presize": "vpr build",
    "size": "size-limit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@standard-schema/utils": "^0.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "mix-n-matchers": "^2.3.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.1",
    "msw": "^2.15.0",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "typescript": "^7.0.2",
    "valibot": "^1.4.2",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  }
}
